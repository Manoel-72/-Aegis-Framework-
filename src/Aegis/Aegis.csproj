<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>Aegis</AssemblyName>
    <RootNamespace>Aegis</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Version>0.9.0</Version>
    <Authors>Aegis Engine</Authors>
    <Description>Aegis 2D Game Engine - Lua scripted, sprites, animator, tilemaps, save/config, particles, tween, debug overlay and hot reload</Description>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.1.303" />
    <PackageReference Include="NLua"                         Version="1.7.3" />
    <PackageReference Include="SpriteFontPlus"               Version="0.9.2" />
  </ItemGroup>
</Project>
