BT /F1 10 Tf 50 750 Td 14 TL (10. Para menus, desligue a camera com `aegis.setCameraOff\(\)`.) Tj T* () Tj T* () Tj T* (11. Exemplo minimo de menu) Tj T* () Tj T* (local title) Tj T* () Tj T* (local function load_font\(\)) Tj T* (local ok, font = pcall\(aegis.loadFont, "Inter-Regular.ttf", 24\)) Tj T* (return ok and font or nil) Tj T* (end) Tj T* () Tj T* (function aegis_init\(\)) Tj T* (aegis.clearAll\(\)) Tj T* (if aegis.setCameraOff then aegis.setCameraOff\(\) end) Tj T* (local font = load_font\(\)) Tj T* (local bg = aegis.newRect\(1280, 720, 0.04, 0.05, 0.08\)) Tj T* (aegis.setPosition\(bg, 0, 0\)) Tj T* (title = aegis.newLabel\("MEU JOGO"\)) Tj T* (if font then aegis.setFont\(title, font\) end) Tj T* (aegis.setPosition\(title, 100, 100\)) Tj T* (aegis.setColor\(title, 1.0, 0.8, 0.3\)) Tj T* (end) Tj T* () Tj T* (function aegis_update\(dt\)) Tj T* (if aegis.keyPressed\("Enter"\) then) Tj T* (aegis.transitionTo\("game", "fade", 0.35\)) Tj T* (end) Tj T* (end) Tj T* () Tj T* () Tj T* (12. Exemplo minimo de player com fisica) Tj T* () Tj T* (local player, rb) Tj T* () Tj T* (function aegis_init\(\)) Tj T* (aegis.clearAll\(\)) Tj T* (player = aegis.newRect\(32, 48, 0.2, 0.8, 0.4\)) Tj T* (aegis.setPosition\(player, 100, 100\)) Tj T* (rb = aegis.addRigidbody\(player\)) Tj T* (local col = aegis.addCollider\(player, 32, 48, 0, 0\)) Tj T* (aegis.setColliderLayer\(col, "PLAYER"\)) Tj T* (aegis.setColliderMask\(col, "WORLD"\)) Tj T* (end) Tj T* () Tj T* (function aegis_update\(dt\)) Tj T* (local vx = 0) Tj T* (if aegis.keyDown\("A"\) then vx = vx - 180 end) Tj T* ET
endstream
