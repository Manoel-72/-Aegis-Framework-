<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="260"
             d:DesignHeight="600"
             x:Class="AegisEditor.Views.HierarchyPanel">

    <Border Background="{DynamicResource AeSurfaceBrush}"
            BorderBrush="{DynamicResource AeBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8">

        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="Hierarchy"
                       FontSize="13"
                       Margin="2 4 2 12"
                       Foreground="{DynamicResource AeTextBrush}" />

            <ListBox ItemsSource="{Binding Entities}"
                     SelectedItem="{Binding SelectedEntity}"
                     Margin="2"
                     BorderThickness="0"
                     Background="Transparent">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="2 6">
                            <Border Width="8" Height="8" Margin="8 8 14 8" DockPanel.Dock="Left"
                                    CornerRadius="12" VerticalAlignment="Center"
                                    Background="{DynamicResource AeAccent}" />
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontFamily="{DynamicResource AeFontMono}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AeTextBrush}" />
                                <TextBlock Text="{Binding Type}" FontSize="11"
                                           Foreground="#6b7280" Margin="0 2 0 0" />
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
