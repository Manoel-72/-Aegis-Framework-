<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:AegisEditor.Views"
        xmlns:controls="using:AegisEditor.Controls"
        Title="Aegis Editor"
        MinWidth="1180"
        MinHeight="760"
        Width="1440"
        Height="900"
        x:Class="AegisEditor.Views.MainWindow"
        Background="{DynamicResource AeBackgroundBrush}">

    <Grid Margin="16">
        <Grid IsVisible="{Binding IsHubVisible}"
              RowDefinitions="Auto,*"
              ColumnDefinitions="1.05*,32,1*">
            <DockPanel Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Margin="0,0,0,24">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Aegis Editor"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AeTextBrush}" />
                    <TextBlock Text="Hub de projetos 2D"
                               Margin="2,4,0,0"
                               FontSize="15"
                               Foreground="#9ca3af" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource AeFontMono}"
                           Foreground="#6b7280"
                           Text="v0.9.9" />
            </DockPanel>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="{DynamicResource AeSurfaceBrush}"
                    BorderBrush="{DynamicResource AeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28">
                <StackPanel Spacing="14">
                    <TextBlock Text="Comecar"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding HubStatus}"
                               Margin="0,0,0,8"
                               Foreground="#9ca3af"
                               TextWrapping="Wrap" />

                    <Button Content="Novo Projeto"
                            MinHeight="48"
                            HorizontalContentAlignment="Left"
                            Padding="18,12"
                            Command="{Binding NewProjectCommand}" />

                    <Button Content="Abrir Projeto"
                            MinHeight="48"
                            HorizontalContentAlignment="Left"
                            Padding="18,12"
                            Click="OpenProjectButton_OnClick" />

                    <Button Content="Abrir Exemplo"
                            MinHeight="48"
                            HorizontalContentAlignment="Left"
                            Padding="18,12"
                            Command="{Binding OpenExampleCommand}" />

                    <Button Content="Documentacao"
                            MinHeight="48"
                            HorizontalContentAlignment="Left"
                            Padding="18,12"
                            Command="{Binding OpenDocumentationCommand}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="2"
                    Background="{DynamicResource AeSurfaceBrush}"
                    BorderBrush="{DynamicResource AeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel>
                        <TextBlock Text="Projetos Recentes"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Abra rapidamente projetos usados nesta maquina."
                                   Margin="0,4,0,18"
                                   Foreground="#9ca3af"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding RecentProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,10"
                                            MinHeight="48"
                                            Padding="14,10"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding $parent[Window].DataContext.OpenRecentProjectCommand}"
                                            CommandParameter="{Binding}">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="{DynamicResource AeFontMono}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1"
                                                       Text="Abrir"
                                                       Margin="0,4,0,0"
                                                       Foreground="#9ca3af"
                                                       FontSize="12" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsWorkspaceVisible}"
              Margin="-16"
              RowDefinitions="24,54,*,6,240,20"
              ColumnDefinitions="280,6,*,6,260">

            <Border Grid.Row="0"
                    Grid.ColumnSpan="5"
                    Background="#092036"
                    BorderBrush="#164566"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">
                    <Menu DockPanel.Dock="Left"
                          Background="Transparent"
                          Margin="2,0,0,0">
                        <MenuItem Header="File">
                            <MenuItem Header="New Project"
                                      Command="{Binding NewProjectCommand}" />
                            <MenuItem Header="New Scene"
                                      Command="{Binding NewSceneCommand}" />
                            <MenuItem Header="Save Scene"
                                      Command="{Binding SaveSceneCommand}" />
                            <Separator />
                            <MenuItem Header="Project Hub"
                                      Command="{Binding BackToHubCommand}" />
                        </MenuItem>
                        <MenuItem Header="Edit">
                            <MenuItem Header="Undo"
                                      Command="{Binding UndoCommand}" />
                            <MenuItem Header="Redo"
                                      Command="{Binding RedoCommand}" />
                            <Separator />
                            <MenuItem Header="Delete Selected"
                                      Command="{Binding DeleteSelectedEntityCommand}" />
                        </MenuItem>
                        <MenuItem Header="View">
                            <MenuItem Header="Toggle Snap"
                                      Command="{Binding ToggleSnapCommand}" />
                            <MenuItem Header="Toggle Grid"
                                      Command="{Binding Viewport.ToggleGridCommand}" />
                            <MenuItem Header="Reset Grid"
                                      Command="{Binding Viewport.ResetGridCommand}" />
                            <MenuItem Header="Reset Scene View"
                                      Command="{Binding ResetEditorViewCommand}" />
                        </MenuItem>
                        <MenuItem Header="Tools">
                            <MenuItem Header="Validate Assets"
                                      Command="{Binding ValidateAssetsCommand}" />
                            <Separator />
                            <MenuItem Header="Play"
                                      Command="{Binding RunGameAndConnectCommand}" />
                            <MenuItem Header="Stop Runtime"
                                      Command="{Binding StopCommand}" />
                            <MenuItem Header="Restart Runtime"
                                      Command="{Binding RestartRuntimeCommand}" />
                        </MenuItem>
                        <MenuItem Header="Help">
                            <MenuItem Header="Documentation"
                                      Command="{Binding OpenDocumentationCommand}" />
                        </MenuItem>
                    </Menu>
                    <TextBlock Text="{Binding CurrentProjectName}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource AeTextSecondaryBrush}" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1"
                  Grid.ColumnSpan="5"
                  Background="#071a2a">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#12395b"
                        BorderBrush="{DynamicResource AeBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding BackToHubCommand}"
                                MinWidth="58"
                                Padding="8,4">
                            <StackPanel>
                                <TextBlock Text="Project" FontSize="11" HorizontalAlignment="Center" />
                                <TextBlock Text="Open" FontSize="10" Foreground="{DynamicResource AeTextSecondaryBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NewSceneCommand}"
                                MinWidth="58"
                                Padding="8,4">
                            <StackPanel>
                                <TextBlock Text="Scene" FontSize="11" HorizontalAlignment="Center" />
                                <TextBlock Text="New" FontSize="10" Foreground="{DynamicResource AeTextSecondaryBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button IsEnabled="False"
                                MinWidth="58"
                                Padding="8,4">
                            <StackPanel>
                                <TextBlock Text="Build" FontSize="11" HorizontalAlignment="Center" />
                                <TextBlock Text="Soon" FontSize="10" Foreground="{DynamicResource AeTextSecondaryBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RunGameAndConnectCommand}"
                                MinWidth="58"
                                Background="#167246"
                                Padding="8,4">
                            <StackPanel>
                                <TextBlock Text="Play" FontSize="11" HorizontalAlignment="Center" />
                                <TextBlock Text="Run" FontSize="10" Foreground="#bff7d5" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding StopCommand}"
                                MinWidth="58"
                                Padding="8,4">
                            <StackPanel>
                                <TextBlock Text="Stop" FontSize="11" HorizontalAlignment="Center" />
                                <TextBlock Text="Runtime" FontSize="10" Foreground="{DynamicResource AeTextSecondaryBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RestartRuntimeCommand}"
                                MinWidth="58"
                                Padding="8,4">
                            <StackPanel>
                                <TextBlock Text="Restart" FontSize="11" HorizontalAlignment="Center" />
                                <TextBlock Text="Run" FontSize="10" Foreground="{DynamicResource AeTextSecondaryBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SaveSceneCommand}"
                                MinWidth="58"
                                Padding="8,4">
                            <StackPanel>
                                <TextBlock Text="Save" FontSize="11" HorizontalAlignment="Center" />
                                <TextBlock Text="Scene" FontSize="10" Foreground="{DynamicResource AeTextSecondaryBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Text="{Binding SceneProjectPath}"
                           FontFamily="{DynamicResource AeFontMono}"
                           FontSize="11"
                           Foreground="{DynamicResource AeTextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="420" />
            </Grid>

            <views:HierarchyPanel Grid.Row="2"
                                  Grid.Column="0"
                                  Margin="0"
                                  DataContext="{Binding Hierarchy}" />

            <GridSplitter Grid.Row="2"
                          Grid.Column="1"
                          Width="6"
                          Background="{DynamicResource AeBorderBrush}" />

            <Border Grid.Row="2"
                    Grid.Column="2"
                    Margin="0"
                    Background="{DynamicResource AePanelDeepBrush}"
                    BorderBrush="{DynamicResource AeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Height="24"
                            Background="#0d2c48"
                            BorderBrush="{DynamicResource AeBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,3">
                        <DockPanel>
                            <TextBlock Text="Scene View (2D)"
                                       FontSize="12"
                                       Foreground="{DynamicResource AeTextBrush}" />
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        Spacing="6">
                                <Button Content="Grid"
                                        Padding="8,1"
                                        Command="{Binding Viewport.ToggleGridCommand}" />
                                <Button Content="-"
                                        MinWidth="24"
                                        Padding="6,1"
                                        Command="{Binding Viewport.DecreaseGridCommand}" />
                                <TextBlock Text="{Binding Viewport.GridSize}"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource AeTextSecondaryBrush}" />
                                <Button Content="+"
                                        MinWidth="24"
                                        Padding="6,1"
                                        Command="{Binding Viewport.IncreaseGridCommand}" />
                                <Button Content="32"
                                        MinWidth="28"
                                        Padding="6,1"
                                        Command="{Binding Viewport.ResetGridCommand}" />
                                <Button Content="Snap"
                                        Padding="8,1"
                                        Command="{Binding Viewport.ToggleSnapCommand}" />
                                <Button Content="Reset"
                                        Padding="8,1"
                                        Command="{Binding Viewport.ResetViewCommand}" />
                                <TextBlock Text="{Binding Viewport.Zoom, StringFormat={}{0:0.00}x}"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource AeTextSecondaryBrush}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <controls:SceneViewport DataContext="{Binding Viewport}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="2"
                          Grid.Column="3"
                          Width="6"
                          Background="{DynamicResource AeBorderBrush}" />

            <views:InspectorPanel Grid.Row="2"
                                  Grid.Column="4"
                                  Margin="2"
                                  DataContext="{Binding Inspector}" />

            <GridSplitter Grid.Row="3"
                          Grid.ColumnSpan="5"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource AeBorderBrush}" />

            <Grid Grid.Row="4"
                  Grid.ColumnSpan="5"
                  Margin="0"
                  ColumnDefinitions="0.95*,6,1.15*">
                <views:AssetBrowserPanel Grid.Column="0"
                                         DataContext="{Binding AssetBrowser}"
                                         HorizontalAlignment="Stretch" />

                <GridSplitter Grid.Column="1"
                              Width="6"
                              Background="{DynamicResource AeBorderBrush}" />

                <views:ConsolePanel Grid.Column="2"
                                    DataContext="{Binding ConsoleLog}"
                                    HorizontalAlignment="Stretch" />
            </Grid>

            <Border Grid.Row="5"
                    Grid.ColumnSpan="5"
                    Background="#071a2a"
                    BorderBrush="#164566"
                    BorderThickness="0,1,0,0"
                    Padding="8,2">
                <DockPanel>
                    <TextBlock Text="Aegis Editor 2D"
                               FontSize="11"
                               Foreground="{DynamicResource AeTextSecondaryBrush}" />
                    <TextBlock DockPanel.Dock="Right"
                               FontSize="11"
                               Foreground="{DynamicResource AeTextSecondaryBrush}">
                        Entities
                        <Run Text="{Binding Hierarchy.Entities.Count}" />
                    </TextBlock>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
