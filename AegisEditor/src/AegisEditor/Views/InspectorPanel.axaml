<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="260"
             d:DesignHeight="640"
             x:Class="AegisEditor.Views.InspectorPanel">

    <Border Background="{DynamicResource AeSurfaceBrush}"
            BorderBrush="{DynamicResource AeBorderBrush}"
            BorderThickness="1"
            CornerRadius="2"
            Padding="0">

        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Height="26"
                    Background="#0d2c48"
                    BorderBrush="{DynamicResource AeBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,4">
                <TextBlock Text="Inspector"
                           FontSize="12"
                           Foreground="{DynamicResource AeTextBrush}" />
            </Border>

            <ScrollViewer>
                <StackPanel Margin="8"
                            Spacing="8">
                    <TextBox Text="{Binding Target.Name}"
                             AcceptsReturn="False"
                             FontWeight="SemiBold" />

                    <Grid ColumnDefinitions="56,*"
                          ColumnSpacing="8">
                        <TextBlock Text="Type"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource AeTextSecondaryBrush}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Target.Type}"
                                 IsReadOnly="True"
                                 FontFamily="{DynamicResource AeFontMono}" />
                    </Grid>

                    <Border Background="#0d2c48"
                            BorderBrush="{DynamicResource AeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <StackPanel>
                            <Border Background="#134060"
                                    Padding="8,5"
                                    BorderBrush="{DynamicResource AeBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <TextBlock Text="Transform"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>

                            <Grid Margin="8"
                                  RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="70,*,*"
                                  RowSpacing="8"
                                  ColumnSpacing="8">
                                <TextBlock Text="Position"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource AeTextSecondaryBrush}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Target.X, Mode=TwoWay}"
                                         FontFamily="{DynamicResource AeFontMono}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding Target.Y, Mode=TwoWay}"
                                         FontFamily="{DynamicResource AeFontMono}" />

                                <TextBlock Grid.Row="1"
                                           Text="Scale"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource AeTextSecondaryBrush}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Text="{Binding Target.ScaleX, Mode=TwoWay}"
                                         FontFamily="{DynamicResource AeFontMono}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="2"
                                         Text="{Binding Target.ScaleY, Mode=TwoWay}"
                                         FontFamily="{DynamicResource AeFontMono}" />

                                <TextBlock Grid.Row="2"
                                           Text="Rotation"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource AeTextSecondaryBrush}" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Target.Rotation, Mode=TwoWay}"
                                         FontFamily="{DynamicResource AeFontMono}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#0d2c48"
                            BorderBrush="{DynamicResource AeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <StackPanel>
                            <Border Background="#134060"
                                    Padding="8,5"
                                    BorderBrush="{DynamicResource AeBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <TextBlock Text="Sprite Renderer"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                            <Grid Margin="8"
                                  RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="70,*"
                                  RowSpacing="8"
                                  ColumnSpacing="8">
                                <TextBlock Text="Texture"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AeTextSecondaryBrush}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Target.TexturePath, Mode=TwoWay}"
                                         FontFamily="{DynamicResource AeFontMono}" />
                                <TextBlock Grid.Row="1"
                                           Text="Script"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AeTextSecondaryBrush}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Text="{Binding Target.ScriptPath, Mode=TwoWay}"
                                         FontFamily="{DynamicResource AeFontMono}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
